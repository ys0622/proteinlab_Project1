{
  "name": "proteinlab",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-products-json.mjs && next build --webpack",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint",
    "audit:assets": "node scripts/audit-asset-coverage.mjs",
    "check:assets": "node scripts/audit-asset-coverage.mjs --strict",
    "audit:products": "node scripts/audit-product-impact.mjs",
    "audit:purchase-links": "node scripts/audit-purchase-link-sync.mjs",
    "audit:bcaa": "python scripts/fill-bcaa-from-spec.py",
    "sync:specs": "node scripts/sync-spec-images.mjs && npm run check:assets",
    "predeploy": "npm run check:assets",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && node scripts/patch-worker-robots.mjs && node deploy.cjs",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.17.1",
    "cheerio": "^1.2.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "patch-package": "^8.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.71.0"
  }
}
